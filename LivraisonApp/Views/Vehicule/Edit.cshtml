@model Vehicule
@{
    ViewData["Title"] = "Modifier véhicule";
}
<div class="page-header">
    <h2><i class="bi bi-pencil-square me-2 text-warning"></i>Modifier véhicule</h2>
    <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>
<div class="form-card">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3"></div>
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Marque" class="form-label">Marque <span class="text-danger">*</span></label>
                <input asp-for="Marque" class="form-control" />
                <span asp-validation-for="Marque" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Matricule" class="form-label">Matricule <span class="text-danger">*</span></label>
                <input asp-for="Matricule" class="form-control font-monospace" />
                <span asp-validation-for="Matricule" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Couleur" class="form-label">Couleur</label>
                <input asp-for="Couleur" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="VitesseLimite" class="form-label">Vitesse limite (km/h)</label>
                <input asp-for="VitesseLimite" class="form-control" />
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-warning text-white"><i class="bi bi-check-lg me-1"></i>Mettre à jour</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Annuler</a>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }