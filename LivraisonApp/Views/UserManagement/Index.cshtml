@model IEnumerable<UserManagementViewModel>
@{
    ViewData["Title"] = "Gestion des utilisateurs";
}
<div class="page-header">
    <h2><i class="bi bi-shield-check me-2 text-danger"></i>Gestion des utilisateurs</h2>
</div>

<div class="search-toolbar">
    <div class="search-input-wrap">
        <i class="bi bi-search search-icon"></i>
        <input type="search" class="search-input" data-table-search="#dataTable" placeholder="Rechercher un utilisateur (e-mail, rôle, statut…)  —  appuyez sur /" autocomplete="off" />
        <button type="button" class="search-clear" hidden title="Effacer"><i class="bi bi-x-circle-fill"></i></button>
    </div>
    <div class="search-meta">
        <span class="search-count"><i class="bi bi-funnel"></i><span class="search-count-num">0</span> résultats</span>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="dataTable">
            <thead>
                <tr>
                    <th>E-mail</th><th>Rôle</th><th>Statut</th><th>Confirmé</th><th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="avatar @(u.Role == "Admin" ? "" : "avatar-green")" style="width:30px;height:30px;font-size:.65rem">
                                    @(u.Email?.Length > 0 ? u.Email[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <a href="mailto:@u.Email" class="fw-semibold">@u.Email</a>
                                    @if (u.IsLocked) { <span class="badge bg-danger ms-1" style="font-size:.6rem"><i class="bi bi-lock-fill"></i> Verrouillé</span> }
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge @(u.Role == "Admin" ? "bg-danger" : "bg-success")">
                                <i class="bi bi-@(u.Role == "Admin" ? "shield-fill" : "person-fill") me-1"></i>@u.Role
                            </span>
                        </td>
                        <td>
                            @if (u.IsLocked)
                            {
                                <span class="status-badge sb-attente"><i class="bi bi-lock me-1"></i>Protégé</span>
                            }
                            else
                            {
                                <span class="status-badge sb-livre"><i class="bi bi-check-circle me-1"></i>Actif</span>
                            }
                        </td>
                        <td>
                            @if (u.EmailConfirmed)
                            {
                                <span class="status-badge sb-livre"><i class="bi bi-envelope-check me-1"></i>Confirmé</span>
                            }
                            else
                            {
                                <span class="status-badge sb-attente"><i class="bi bi-envelope-x me-1"></i>En attente</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="action-links justify-content-center">
                                @if (!u.IsLocked)
                                {
                                    <form asp-action="LockUser" method="post" style="display:inline">
                                        <input type="hidden" name="userId" value="@u.Id" />
                                        <button class="btn btn-sm btn-outline-danger" title="Verrouiller"><i class="bi bi-lock"></i></button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="UnlockUser" method="post" style="display:inline">
                                        <input type="hidden" name="userId" value="@u.Id" />
                                        <button class="btn btn-sm btn-outline-success" title="Déverrouiller"><i class="bi bi-unlock"></i></button>
                                    </form>
                                }
                                @if (u.Role != "Admin")
                                {
                                    <form asp-action="PromoteToAdmin" method="post" style="display:inline">
                                        <input type="hidden" name="userId" value="@u.Id" />
                                        <button class="btn btn-sm btn-outline-warning" title="Promouvoir Admin"><i class="bi bi-star"></i></button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5">
                        <div class="empty-state">
                            <div class="empty-icon"><i class="bi bi-people"></i></div>
                            <h6>Aucun utilisateur</h6>
                        </div>
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
@section Scripts { <script>new DataTable('#dataTable', { language: { url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/fr-FR.json' } });</script> }