@model Client
@{
    ViewData["Title"] = "Nouveau client";
}
<div class="page-header">
    <h2><i class="bi bi-person-plus me-2 text-primary"></i>Nouveau client</h2>
    <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>
<div class="form-card">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Nom" class="form-label">Nom <span class="text-danger">*</span></label>
                <input asp-for="Nom" class="form-control" placeholder="Nom de famille" />
                <span asp-validation-for="Nom" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Prenom" class="form-label">Prénom</label>
                <input asp-for="Prenom" class="form-control" placeholder="Prénom" />
            </div>
            <div class="col-md-6">
                <label asp-for="Ville" class="form-label">Ville</label>
                <input asp-for="Ville" class="form-control" placeholder="Ex: Alger" />
            </div>
            <div class="col-md-6">
                <label asp-for="CodePostal" class="form-label">Code postal</label>
                <input asp-for="CodePostal" class="form-control" placeholder="Ex: 16000" />
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Enregistrer</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Annuler</a>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }