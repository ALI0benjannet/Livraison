@model IEnumerable<Client>
@{
    ViewData["Title"] = "Clients";
}
<div class="page-header">
    <h2><i class="bi bi-people me-2 text-success"></i>Gestion des clients</h2>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>Nouveau client</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="dataTable">
            <thead>
                <tr>
                    <th>#</th><th>Client</th><th>Ville</th><th>Code postal</th><th>Nb colis</th><th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="text-muted">@c.Id</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="avatar avatar-green" style="width:30px;height:30px;font-size:.65rem">
                                    @(c.Nom?.Length > 0 ? c.Nom[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <div class="fw-semibold">@c.Nom @c.Prenom</div>
                                </div>
                            </div>
                        </td>
                        <td><i class="bi bi-geo-alt me-1 text-muted"></i>@c.Ville</td>
                        <td>@c.CodePostal</td>
                        <td><span class="badge bg-primary">@c.Colis.Count</span></td>
                        <td class="text-center">
                            <div class="action-links justify-content-center">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@c.Id" title="Détails"><i class="bi bi-eye"></i></a>
                                <a class="btn btn-sm btn-outline-warning" asp-action="Edit" asp-route-id="@c.Id" title="Modifier"><i class="bi bi-pencil"></i></a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@c.Id" title="Supprimer"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6">
                        <div class="empty-state">
                            <div class="empty-icon"><i class="bi bi-people"></i></div>
                            <h6>Aucun client</h6>
                            <p>Aucun client enregistré pour le moment.</p>
                        </div>
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
@section Scripts { <script>new DataTable('#dataTable', { language: { url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/fr-FR.json' } });</script> }