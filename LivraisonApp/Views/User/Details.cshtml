@model Colis
@{
    ViewData["Title"] = "DÈtail colis";
}
<div class="page-header">
    <h2><i class="bi bi-box-seam me-2 text-primary"></i>DÈtail colis #@Model?.Id</h2>
    <a class="btn btn-outline-secondary" asp-action="Colis"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>
<div class="form-card">
    <div class="row g-3">
        <div class="col-md-6">
            <div class="text-muted small fw-semibold text-uppercase mb-1">LibellÈ</div>
            <div class="fs-6 fw-semibold">@(Model?.Libelle ?? "ó")</div>
        </div>
        <div class="col-md-6">
            <div class="text-muted small fw-semibold text-uppercase mb-1">Date de livraison</div>
            <div><i class="bi bi-calendar3 me-1 text-primary"></i>@Model?.DateLivraison.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="col-md-4">
            <div class="text-muted small fw-semibold text-uppercase mb-1">Montant</div>
            <div class="fs-4 fw-bold text-success">@Model?.Montant.ToString("N2") DZD</div>
        </div>
        <div class="col-md-4">
            <div class="text-muted small fw-semibold text-uppercase mb-1">Poids</div>
            <div>@Model?.Poids kg</div>
        </div>
        <div class="col-md-4">
            <div class="text-muted small fw-semibold text-uppercase mb-1">Volume</div>
            <div>@Model?.Volume m≥</div>
        </div>
        <div class="col-md-6">
            <div class="text-muted small fw-semibold text-uppercase mb-1">Client</div>
            <div><i class="bi bi-person me-1 text-primary"></i>@Model?.Client?.Nom @Model?.Client?.Prenom ó @Model?.Client?.Ville</div>
        </div>
        <div class="col-md-6">
            <div class="text-muted small fw-semibold text-uppercase mb-1">Livreur</div>
            <div><i class="bi bi-person-badge me-1 text-primary"></i>@Model?.Livreur?.CIN ó @Model?.Livreur?.Ville</div>
        </div>
    </div>
</div>
