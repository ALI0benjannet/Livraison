@model IEnumerable<Colis>
@{
    ViewData["Title"] = "Recherche colis";
    var s = ViewBag.Search as ColisSearchViewModel;
}
<div class="page-header">
    <h2><i class="bi bi-search me-2 text-primary"></i>Recherche de colis</h2>
</div>

<div class="search-card">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label small fw-bold">Prix min (DZD)</label>
            <input class="form-control" name="PrixMin" value="@s?.PrixMin" placeholder="0" type="number" step="0.01" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Prix max (DZD)</label>
            <input class="form-control" name="PrixMax" value="@s?.PrixMax" placeholder="999999" type="number" step="0.01" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Date livraison</label>
            <input class="form-control" name="DateLivraison" value="@s?.DateLivraison?.ToString("yyyy-MM-dd")" type="date" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Libellé</label>
            <input class="form-control" name="Libelle" value="@s?.Libelle" placeholder="Mot-clé..." />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Statut</label>
            <select class="form-select" name="Statut">
                <option value="">-- Tous --</option>
                <option value="EnAttente" selected="@(s?.Statut == StatutColis.EnAttente)">? En attente</option>
                <option value="EnCours"   selected="@(s?.Statut == StatutColis.EnCours)">?? En cours</option>
                <option value="Livre"     selected="@(s?.Statut == StatutColis.Livre)">? Livré</option>
            </select>
        </div>
        <div class="col-md-1">
            <label class="form-label small fw-bold">Ville</label>
            <input class="form-control" name="Ville" value="@s?.Ville" placeholder="Alger" />
        </div>
        <div class="col-md-1 d-flex gap-1 align-items-end">
            <button class="btn btn-primary flex-fill"><i class="bi bi-search"></i></button>
            <a class="btn btn-outline-secondary" asp-action="Colis"><i class="bi bi-x"></i></a>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-list-ul me-2"></i>Résultats</span>
        <span class="badge bg-primary">@Model.Count() colis trouvé(s)</span>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>Libellé</th><th>Statut</th><th>Date</th><th>Montant</th><th>Client</th><th>Ville</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    var (cls2, ico2, lbl2) = c.Statut switch {
                            StatutColis.EnCours => ("status-en-cours", "bi-truck", "En cours"),
                            StatutColis.Livre   => ("status-livre",    "bi-check-circle-fill", "Livré"),
                            _                   => ("status-en-attente", "bi-hourglass-split", "En attente")
                        };
                    <tr>
                        <td class="fw-semibold">@(c.Libelle ?? "—")</td>
                        <td><span class="status-badge @cls2"><i class="bi @ico2 me-1"></i>@lbl2</span></td>
                        <td><i class="bi bi-calendar3 me-1 text-muted"></i>@c.DateLivraison.ToShortDateString()</td>
                        <td class="text-success fw-semibold">@c.Montant.ToString("N2") DZD</td>
                        <td><i class="bi bi-person me-1 text-muted"></i>@c.Client?.Nom @c.Client?.Prenom</td>
                        <td><i class="bi bi-geo-alt me-1 text-muted"></i>@c.Client?.Ville</td>
                        <td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@c.Id"><i class="bi bi-eye"></i></a></td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>Aucun colis ne correspond aux critčres de recherche.
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="page-header">
    <h2><i class="bi bi-search me-2 text-primary"></i>Recherche de colis</h2>
</div>

<div class="search-card">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Prix min (DZD)</label>
            <input class="form-control" name="PrixMin" value="@s?.PrixMin" placeholder="0" type="number" step="0.01" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Prix max (DZD)</label>
            <input class="form-control" name="PrixMax" value="@s?.PrixMax" placeholder="999999" type="number" step="0.01" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Date livraison</label>
            <input class="form-control" name="DateLivraison" value="@s?.DateLivraison?.ToString("yyyy-MM-dd")" type="date" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Libellé</label>
            <input class="form-control" name="Libelle" value="@s?.Libelle" placeholder="Mot-clé..." />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">Ville client</label>
            <input class="form-control" name="Ville" value="@s?.Ville" placeholder="Ex: Alger" />
        </div>
        <div class="col-md-1">
            <label class="form-label small fw-semibold">CIN livreur</label>
            <input class="form-control" name="Livreur" value="@s?.Livreur" placeholder="CIN" />
        </div>
        <div class="col-md-1 d-flex gap-1">
            <button class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
            <a class="btn btn-outline-secondary" asp-action="Colis"><i class="bi bi-x"></i></a>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-box-seam me-2"></i>Résultats</span>
        <span class="badge bg-primary">@Model.Count() colis trouvé(s)</span>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>Libellé</th><th>Date livraison</th><th>Montant</th><th>Poids</th><th>Client</th><th>Ville</th><th>Livreur</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="fw-semibold">@(c.Libelle ?? "—")</td>
                        <td><i class="bi bi-calendar3 me-1 text-muted"></i>@c.DateLivraison.ToShortDateString()</td>
                        <td><span class="text-success fw-semibold">@c.Montant.ToString("N2") DZD</span></td>
                        <td>@c.Poids kg</td>
                        <td><i class="bi bi-person me-1 text-muted"></i>@c.Client?.Nom @c.Client?.Prenom</td>
                        <td><i class="bi bi-geo-alt me-1 text-muted"></i>@c.Client?.Ville</td>
                        <td><i class="bi bi-person-badge me-1 text-muted"></i>@c.Livreur?.CIN</td>
                        <td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@c.Id"><i class="bi bi-eye"></i></a></td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Aucun colis trouvé</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
