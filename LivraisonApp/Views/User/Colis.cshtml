@using LivraisonApp.Models
@using LivraisonApp.ViewModels
@model IEnumerable<Colis>
@{
    ViewData["Title"] = "Mes colis";
    var s = ViewBag.Search as ColisSearchViewModel ?? new ColisSearchViewModel();
    var livreurInfos = ViewBag.LivreurInfos as IDictionary<int, object>;
    string? PhoneOf(int id) {
        if (livreurInfos != null && livreurInfos.TryGetValue(id, out var o))
            return (string?)o.GetType().GetProperty("PhoneNumber")?.GetValue(o);
        return null;
    }
}

<div class="page-header">
    <h2><i class="bi bi-box-seam me-2 text-primary"></i>Mes colis</h2>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]</div>
}

<div class="form-card mb-3">
    <form method="get" asp-action="Colis" class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small text-muted">Libellé</label>
            <input type="text" name="Libelle" value="@s.Libelle" class="form-control" placeholder="Rechercher un libellé..." />
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">Livreur (nom / CIN)</label>
            <input type="text" name="Livreur" value="@s.Livreur" class="form-control" placeholder="Express, 12345..." />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted">Prix min (DZD)</label>
            <input type="number" step="0.01" name="PrixMin" value="@s.PrixMin" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted">Prix max (DZD)</label>
            <input type="number" step="0.01" name="PrixMax" value="@s.PrixMax" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted">Statut</label>
            <select name="Statut" class="form-select">
                <option value="">— Tous —</option>
                <option value="EnAttente" selected="@(s.Statut == StatutColis.EnAttente)">En attente</option>
                <option value="EnCours" selected="@(s.Statut == StatutColis.EnCours)">En cours</option>
                <option value="Livre" selected="@(s.Statut == StatutColis.Livre)">Livré</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">Date de livraison</label>
            <input type="date" name="DateLivraison" value="@(s.DateLivraison?.ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="col-md-9 d-flex gap-2 justify-content-end">
            <button class="btn btn-primary"><i class="bi bi-search me-1"></i>Rechercher</button>
            <a asp-action="Colis" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i>Réinitialiser</a>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th><th>Libellé</th><th>Statut</th><th>Date</th><th>Montant</th><th>Livreur</th><th>Tél. livreur</th><th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="text-muted">@c.Id</td>
                        <td class="fw-semibold">@c.Libelle</td>
                        <td>
                            @{
                                var (cls, icon, lbl) = c.Statut switch {
                                    StatutColis.EnAttente => ("status-badge sb-attente", "hourglass-split", "En attente"),
                                    StatutColis.EnCours   => ("status-badge sb-cours",   "truck",           "En cours"),
                                    StatutColis.Livre     => ("status-badge sb-livre",   "check-circle-fill","Livré"),
                                    _                     => ("status-badge sb-attente",  "question",        "Inconnu")
                                };
                            }
                            <span class="@cls"><i class="bi bi-@icon me-1"></i>@lbl</span>
                        </td>
                        <td>@c.DateLivraison.ToString("dd/MM/yyyy")</td>
                        <td class="text-success fw-bold">@c.Montant.ToString("N2") DZD</td>
                        <td>@(c.Livreur is null ? "—" : $"{c.Livreur.RaisonSocial} ({c.Livreur.CIN})")</td>
                        <td>
                            @{ var tel = PhoneOf(c.LivreurId); }
                            @if (!string.IsNullOrEmpty(tel))
                            {
                                <a href="tel:@tel" class="text-decoration-none fw-semibold"><i class="bi bi-telephone-fill text-success me-1"></i>@tel</a>
                            }
                            else { <span class="text-muted small">—</span> }
                        </td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@c.Id"><i class="bi bi-eye"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8">
                        <div class="empty-state">
                            <div class="empty-icon"><i class="bi bi-box-seam"></i></div>
                            <h6>Aucun colis</h6>
                            <p>Aucun colis ne correspond à votre recherche.</p>
                        </div>
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>