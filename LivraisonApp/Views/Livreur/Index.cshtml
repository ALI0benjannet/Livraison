@model IEnumerable<Livreur>
@{
    ViewData["Title"] = "Livreurs";
}
<div class="page-header">
    <h2><i class="bi bi-person-badge me-2 text-warning"></i>Gestion des livreurs</h2>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>Nouveau livreur</a>
</div>

<div class="search-toolbar">
    <div class="search-input-wrap">
        <i class="bi bi-search search-icon"></i>
        <input type="search" class="search-input" data-table-search="#dataTable" placeholder="Rechercher un livreur (CIN, raison sociale, ville, véhicule…)  —  appuyez sur /" autocomplete="off" />
        <button type="button" class="search-clear" hidden title="Effacer"><i class="bi bi-x-circle-fill"></i></button>
    </div>
    <div class="search-meta">
        <span class="search-count"><i class="bi bi-funnel"></i><span class="search-count-num">0</span> résultats</span>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="dataTable">
            <thead>
                <tr><th>CIN</th><th>Nom &amp; Prénom</th><th>Raison sociale</th><th>Ville</th><th>Véhicule</th><th>Nb colis</th><th class="text-center">Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    <tr>
                        <td class="fw-semibold font-monospace">@l.CIN</td>
                        <td class="fw-semibold">@(((l.Nom ?? "") + " " + (l.Prenom ?? "")).Trim() is { Length: > 0 } np ? np : "—")</td>
                        <td>@(l.RaisonSocial ?? "—")</td>
                        <td><i class="bi bi-geo-alt me-1 text-muted"></i>@l.Ville</td>
                        <td>
                            @if (l.Vehicule != null)
                            {
                                <span class="badge-type @(l.Vehicule.GetType().Name == "Camion" ? "badge-camion" : "badge-voiture")">
                                    <i class="bi bi-@(l.Vehicule.GetType().Name == "Camion" ? "truck" : "car-front") me-1"></i>@l.Vehicule.Matricule
                                </span>
                            }
                            else { <span class="text-muted small">Aucun</span> }
                        </td>
                        <td><span class="badge bg-primary">@l.Colis.Count</span></td>
                        <td class="text-center">
                            <div class="action-links justify-content-center">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@l.Id" title="Détails"><i class="bi bi-eye"></i></a>
                                <a class="btn btn-sm btn-outline-warning" asp-action="Edit" asp-route-id="@l.Id" title="Modifier"><i class="bi bi-pencil"></i></a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@l.Id" title="Supprimer"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7">
                        <div class="empty-state">
                            <div class="empty-icon"><i class="bi bi-person-badge"></i></div>
                            <h6>Aucun livreur</h6>
                            <p>Aucun livreur enregistré pour le moment.</p>
                        </div>
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
@section Scripts { <script>new DataTable('#dataTable', { language: { url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/fr-FR.json' } });</script> }