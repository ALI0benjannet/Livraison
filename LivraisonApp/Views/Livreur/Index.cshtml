@model IEnumerable<Livreur>
@{
    ViewData["Title"] = "Livreurs";
}
<div class="page-header">
    <h2><i class="bi bi-person-badge me-2 text-warning"></i>Gestion des livreurs</h2>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>Nouveau livreur</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="dataTable">
            <thead>
                <tr><th>CIN</th><th>Raison sociale</th><th>Ville</th><th>Véhicule</th><th>Nb colis</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    <tr>
                        <td class="fw-semibold">@l.CIN</td>
                        <td>@(l.RaisonSocial ?? "—")</td>
                        <td><i class="bi bi-geo-alt me-1 text-muted"></i>@l.Ville</td>
                        <td>
                            @if (l.Vehicule != null)
                            {
                                <span class="badge-type @(l.Vehicule.GetType().Name == "Camion" ? "badge-camion" : "badge-voiture")">
                                    <i class="bi bi-truck me-1"></i>@l.Vehicule.Matricule
                                </span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td><span class="badge bg-primary">@l.Colis.Count</span></td>
                        <td class="action-links">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@l.Id"><i class="bi bi-eye"></i></a>
                            <a class="btn btn-sm btn-outline-warning" asp-action="Edit" asp-route-id="@l.Id"><i class="bi bi-pencil"></i></a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@l.Id"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@section Scripts { <script>new DataTable('#dataTable', { language: { url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/fr-FR.json' } });</script> }
