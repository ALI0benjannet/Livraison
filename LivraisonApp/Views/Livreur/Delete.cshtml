@model Livreur
@{
    ViewData["Title"] = "Supprimer livreur";
}
<div class="page-header">
    <h2><i class="bi bi-trash me-2 text-danger"></i>Supprimer livreur</h2>
    <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>
<div class="form-card" style="max-width:480px">
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        Êtes-vous sûr de vouloir supprimer le livreur <strong>@(((Model?.Nom ?? "") + " " + (Model?.Prenom ?? "")).Trim() is { Length: > 0 } np ? np : Model?.CIN)</strong> ?
        <br><small class="mt-1 d-block opacity-75">Cette action est irréversible.</small>
    </div>
    <dl class="row small mt-3">
        <dt class="col-5 text-muted">CIN</dt><dd class="col-7 font-monospace">@Model?.CIN</dd>
        <dt class="col-5 text-muted">Raison sociale</dt><dd class="col-7">@(Model?.RaisonSocial ?? "—")</dd>
        <dt class="col-5 text-muted">Ville</dt><dd class="col-7">@(Model?.Ville ?? "—")</dd>
        <dt class="col-5 text-muted">Colis en charge</dt><dd class="col-7"><span class="badge bg-primary">@(Model?.Colis?.Count ?? 0)</span></dd>
    </dl>
    <form asp-action="Delete" method="post" class="d-flex gap-2 mt-3">
        <input type="hidden" asp-for="Id" />
        <button class="btn btn-danger"><i class="bi bi-trash me-1"></i>Confirmer la suppression</button>
        <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-x me-1"></i>Annuler</a>
    </form>
</div>