@model Livreur
@{
    ViewData["Title"] = "Supprimer livreur";
}
<div class="page-header">
    <h2><i class="bi bi-trash me-2 text-danger"></i>Supprimer livreur</h2>
    <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>
<div class="form-card" style="max-width:480px">
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
         tes-vous s˚r de vouloir supprimer le livreur <strong>@Model?.CIN</strong> ?
    </div>
    <dl class="row small">
        <dt class="col-5 text-muted">Ville</dt><dd class="col-7">@(Model?.Ville ?? "ó")</dd>
        <dt class="col-5 text-muted">VÈhicule</dt><dd class="col-7">@(Model?.Vehicule?.Matricule ?? "ó")</dd>
    </dl>
    <form asp-action="Delete" method="post" class="d-flex gap-2 mt-3">
        <input type="hidden" asp-for="Id" />
        <button class="btn btn-danger"><i class="bi bi-trash me-1"></i>Confirmer la suppression</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Annuler</a>
    </form>
</div>
