@model DashboardViewModel
@{
    ViewData["Title"] = "Tableau de bord";
}

<div class="page-header">
    <h2><i class="bi bi-speedometer2 me-2 text-primary"></i>Tableau de bord</h2>
    <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</span>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-3">
    <div class="col-6 col-xl-2">
        <div class="kpi-card kpi-blue">
            <i class="bi bi-box-seam kpi-icon"></i>
            <div class="kpi-label">Total colis</div>
            <div class="kpi-value">@Model.TotalColis</div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="kpi-card kpi-teal">
            <i class="bi bi-cash-coin kpi-icon"></i>
            <div class="kpi-label">Revenus totaux</div>
            <div class="kpi-value" style="font-size:1.4rem">@Model.TotalRevenue.ToString("N0")</div>
            <div class="kpi-sub">DT</div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="kpi-card kpi-green">
            <i class="bi bi-people kpi-icon"></i>
            <div class="kpi-label">Clients</div>
            <div class="kpi-value">@Model.TotalClients</div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="kpi-card kpi-orange">
            <i class="bi bi-person-badge kpi-icon"></i>
            <div class="kpi-label">Livreurs</div>
            <div class="kpi-value">@Model.TotalLivreurs</div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="kpi-card kpi-purple">
            <i class="bi bi-truck kpi-icon"></i>
            <div class="kpi-label">Véhicules</div>
            <div class="kpi-value">@Model.TotalVehicules</div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="kpi-card kpi-rose">
            <i class="bi bi-hourglass-split kpi-icon"></i>
            <div class="kpi-label">En attente</div>
            <div class="kpi-value">@Model.ColisEnAttente</div>
        </div>
    </div>
</div>

<!-- Statut résumé -->
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="chart-card">
            <h6><i class="bi bi-bar-chart-steps me-2 text-primary"></i>Répartition par statut</h6>
            <div class="statut-progress">
                <div class="statut-item si-attente">
                    <div class="si-value">@Model.ColisEnAttente</div>
                    <div class="si-label"><i class="bi bi-hourglass-split me-1"></i>En attente</div>
                </div>
                <div class="statut-item si-cours">
                    <div class="si-value">@Model.ColisEnCours</div>
                    <div class="si-label"><i class="bi bi-truck me-1"></i>En cours</div>
                </div>
                <div class="statut-item si-livre">
                    <div class="si-value">@Model.ColisLivres</div>
                    <div class="si-label"><i class="bi bi-check-circle-fill me-1"></i>Livrés</div>
                </div>
                @{
                    var total = Model.TotalColis > 0 ? Model.TotalColis : 1;
                    var pct   = (int)Math.Round(Model.ColisLivres * 100.0 / total);
                }
                <div class="statut-item" style="flex:3; background:#f0fdf4; border-radius:12px; padding:1rem; display:flex; flex-direction:column; justify-content:center;">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="fw-bold text-muted">Taux de livraison</small>
                        <small class="fw-bold text-success">@pct%</small>
                    </div>
                    <div class="progress" style="height:10px; border-radius:10px;">
                        <div class="progress-bar bg-success" style="width:@pct%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Graphiques -->
<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <div class="chart-card">
            <h6><i class="bi bi-bar-chart me-2 text-primary"></i>Colis par mois</h6>
            <canvas id="barColis" height="110"></canvas>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="chart-card">
            <h6><i class="bi bi-pie-chart me-2 text-success"></i>Statut des colis</h6>
            <canvas id="pieStatut" height="200"></canvas>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="chart-card">
            <h6><i class="bi bi-graph-up me-2 text-warning"></i>Revenus mensuels (DT)</h6>
            <canvas id="lineRevenue" height="80"></canvas>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="chart-card">
            <h6><i class="bi bi-pie-chart me-2 text-info"></i>Répartition véhicules</h6>
            <canvas id="pieVehicules" height="200"></canvas>
        </div>
    </div>
</div>

<!-- Top clients -->
<div class="card">
    <div class="card-header"><i class="bi bi-trophy-fill me-2 text-warning"></i>Top 5 clients par nombre de colis</div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="topClientsTable">
            <thead><tr><th style="width:60px">#</th><th>Client</th><th>Colis</th></tr></thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
fetch('/Dashboard/Stats').then(r => r.json()).then(d => {
    const labels  = d.colisByMonth.map(x => x.label);
    const totals  = d.colisByMonth.map(x => x.total);
    const revenue = d.colisByMonth.map(x => x.revenue);

    new Chart(document.getElementById('barColis'), {
        type: 'bar',
        data: { labels, datasets: [{ label: 'Colis', data: totals, backgroundColor: 'rgba(59,130,246,0.85)', borderRadius: 7, borderSkipped: false }] },
        options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
    });

    new Chart(document.getElementById('pieStatut'), {
        type: 'doughnut',
        data: {
            labels: ['En attente', 'En cours', 'Livrés'],
            datasets: [{ data: [d.statutData.enAttente, d.statutData.enCours, d.statutData.livre],
                backgroundColor: ['#fef3c7', '#dbeafe', '#d1fae5'],
                borderColor: ['#f59e0b', '#3b82f6', '#10b981'],
                borderWidth: 2 }]
        },
        options: { plugins: { legend: { position: 'bottom' } }, cutout: '60%' }
    });

    new Chart(document.getElementById('lineRevenue'), {
        type: 'line',
        data: { labels, datasets: [{ label: 'Revenus (DT)', data: revenue, borderColor: '#f59e0b',
            backgroundColor: 'rgba(245,158,11,.08)', borderWidth: 2.5, fill: true, tension: 0.4,
            pointBackgroundColor: '#f59e0b', pointRadius: 4 }] },
        options: { scales: { y: { beginAtZero: true } } }
    });

    new Chart(document.getElementById('pieVehicules'), {
        type: 'doughnut',
        data: { labels: ['Camions', 'Voitures'], datasets: [{ data: [d.camions, d.voitures],
            backgroundColor: ['#dbeafe', '#d1fae5'], borderColor: ['#3b82f6', '#10b981'], borderWidth: 2 }] },
        options: { plugins: { legend: { position: 'bottom' } }, cutout: '60%' }
    });

    const tbody = document.querySelector('#topClientsTable tbody');
    const medals = ['🥇','🥈','🥉'];
    d.topClients.forEach((x, i) => {
        const rank = medals[i] || `<span class="badge bg-secondary">${i+1}</span>`;
        tbody.innerHTML += `<tr>
            <td class="text-center fs-5">${rank}</td>
            <td><i class="bi bi-person-circle me-2 text-muted"></i><strong>${x.client}</strong></td>
            <td><span class="badge bg-primary">${x.total} colis</span></td>
        </tr>`;
    });
}).catch(err => console.error('Dashboard Stats error:', err));
</script>
}