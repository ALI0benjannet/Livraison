@model LoginViewModel
@{
    ViewData["Title"] = "Connexion";
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Connexion — LivraisonApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-logo">
            <i class="bi bi-truck-front-fill"></i>
            <h2>LivraisonApp</h2>
            <p>Connectez-vous ŕ votre espace</p>
        </div>
        <form asp-action="Login" method="post">
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3"></div>
            <div class="mb-3">
                <label asp-for="Login" class="form-label">Email / Identifiant</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input asp-for="Login" class="form-control" placeholder="votre@email.com" />
                </div>
                <span asp-validation-for="Login" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">Se souvenir de moi</label>
            </div>
            <button class="btn btn-primary w-100 py-2"><i class="bi bi-box-arrow-in-right me-2"></i>Se connecter</button>
        </form>
        <hr class="my-3" />
        <div class="text-center">
            <span class="text-muted small">Pas encore de compte ?</span>
            <a asp-action="Register" class="ms-1 fw-semibold">Créer un compte</a>
        </div>
    </div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
