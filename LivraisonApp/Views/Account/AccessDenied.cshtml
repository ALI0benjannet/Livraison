@{
    ViewData["Title"] = "Accès refusé";
    Layout = "_Layout";
    var returnUrl = ViewBag.ReturnUrl as string;
    var role = User.IsInRole("Admin") ? "Admin"
             : User.IsInRole("Livreur") ? "Livreur"
             : User.IsInRole("Client") ? "Client"
             : "Utilisateur";
    var (homeCtrl, homeAct) = User.IsInRole("Admin")   ? ("Dashboard", "Index")
                            : User.IsInRole("Livreur") ? ("MesLivraisons", "Index")
                            : User.IsInRole("Client")  ? ("User", "Colis")
                            : ("Account", "Login");
}

<div class="d-flex justify-content-center align-items-center" style="min-height:60vh">
    <div class="card text-center shadow-lg" style="max-width:520px;width:100%;border:none;border-radius:18px;overflow:hidden">
        <div style="background:linear-gradient(135deg,#fef3c7 0%,#fde68a 100%);padding:40px 24px 20px">
            <div style="width:84px;height:84px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;margin:0 auto;box-shadow:0 8px 24px rgba(0,0,0,.08)">
                <i class="bi bi-shield-lock-fill" style="font-size:2.2rem;color:#d97706"></i>
            </div>
            <h3 class="mt-3 mb-1" style="color:#92400e">Accès refusé</h3>
            <p class="mb-0 text-muted">Vous êtes connecté en tant que <strong>@User.Identity!.Name</strong> (@role).</p>
        </div>
        <div class="card-body p-4">
            <p class="mb-4">
                Cette page n'est pas accessible à votre rôle.<br />
                <span class="text-muted small">Votre session reste active — utilisez le menu pour revenir à votre espace.</span>
            </p>
            <div class="d-flex gap-2 justify-content-center flex-wrap">
                <a asp-controller="@homeCtrl" asp-action="@homeAct" class="btn btn-primary">
                    <i class="bi bi-house-door-fill me-1"></i>Mon espace
                </a>
                <a href="javascript:history.back()" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
        </div>
    </div>
</div>
