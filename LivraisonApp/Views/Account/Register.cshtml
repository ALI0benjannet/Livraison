@model RegisterViewModel
@{
    ViewData["Title"] = "Inscription";
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inscription — LivraisonApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="auth-wrapper">
    <div class="auth-card" style="max-width:460px">
        <div class="auth-logo">
            <i class="bi bi-truck-front-fill"></i>
            <h2>LivraisonApp</h2>
            <p>Créez votre compte utilisateur</p>
        </div>
        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>
            <div class="mb-3">
                <label asp-for="Login" class="form-label">Email / Identifiant</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input asp-for="Login" class="form-control" placeholder="votre@email.com" />
                </div>
                <span asp-validation-for="Login" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input asp-for="Password" class="form-control" placeholder="Min. 6 caractčres" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Confirmer le mot de passe</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Répétez le mot de passe" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <input type="hidden" asp-for="Role" value="User" />
            <button class="btn btn-primary w-100 py-2"><i class="bi bi-person-plus me-2"></i>S'inscrire</button>
        </form>
        <hr class="my-3" />
        <div class="text-center">
            <span class="text-muted small">Déjŕ un compte ?</span>
            <a asp-action="Login" class="ms-1 fw-semibold">Se connecter</a>
        </div>
    </div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
