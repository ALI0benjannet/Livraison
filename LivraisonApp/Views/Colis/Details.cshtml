                <div class="text-muted small fw-semibold text-uppercase mb-1">Poids</div>
                <div class="fs-6">@Model?.Poids kg</div>
            </div>
            <div class="mb-3">
                <div class="text-muted small fw-semibold text-uppercase mb-1">Volume</div>
                <div class="fs-6">@Model?.Volume m≥</div>
            </div>
            <div class="mb-3">
                <div class="text-muted small fw-semibold text-uppercase mb-1">Client</div>
                <div class="fs-6"><i class="bi bi-person me-1 text-primary"></i>@Model?.Client?.Nom @Model?.Client?.Prenom ó @Model?.Client?.Ville</div>
            </div>
            <div class="mb-3">
                <div class="text-muted small fw-semibold text-uppercase mb-1">Livreur</div>
                <div class="fs-6"><i class="bi bi-person-badge me-1 text-primary"></i>@Model?.Livreur?.CIN ó @Model?.Livreur?.Ville</div>
            </div>
        </div>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="mt-3 d-flex gap-2">
            <a class="btn btn-warning text-white" asp-action="Edit" asp-route-id="@Model?.Id"><i class="bi bi-pencil me-1"></i>Modifier</a>
            <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model?.Id"><i class="bi bi-trash me-1"></i>Supprimer</a>
        </div>
    }
</div>
