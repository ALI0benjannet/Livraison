@model Colis
@{
    ViewData["Title"] = "Dťtails colis";
    var (cls, ico, lbl) = Model?.Statut switch {
        StatutColis.EnCours => ("status-en-cours", "bi-truck", "En cours"),
        StatutColis.Livre   => ("status-livre",    "bi-check-circle-fill", "Livrť"),
        _                   => ("status-en-attente", "bi-hourglass-split", "En attente")
    };
}
<div class="page-header no-print">
    <h2><i class="bi bi-box-seam me-2 text-primary"></i>Dťtails colis #@Model?.Id</h2>
    <div class="d-flex gap-2">
        <button class="btn btn-print" onclick="window.print()"><i class="bi bi-printer me-1"></i>Imprimer</button>
        <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Retour</a>
    </div>
</div>
<div class="form-card">
    <div class="mb-3">
        <span class="status-badge @cls fs-6"><i class="bi @ico me-1"></i>@lbl</span>
    </div>
    <div class="row g-3">
        <div class="col-md-6">
            <div class="text-muted small fw-bold text-uppercase mb-1">Libellť</div>
            <div class="fw-semibold fs-6">@(Model?.Libelle ?? "ó")</div>
        </div>
        <div class="col-md-6">
            <div class="text-muted small fw-bold text-uppercase mb-1">Date de livraison</div>
            <div><i class="bi bi-calendar3 me-1 text-primary"></i>@Model?.DateLivraison.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="col-md-4">
            <div class="text-muted small fw-bold text-uppercase mb-1">Montant</div>
            <div class="fs-4 fw-bold text-success">@Model?.Montant.ToString("N2") DZD</div>
        </div>
        <div class="col-md-4">
            <div class="text-muted small fw-bold text-uppercase mb-1">Poids</div>
            <div>@Model?.Poids kg</div>
        </div>
        <div class="col-md-4">
            <div class="text-muted small fw-bold text-uppercase mb-1">Volume</div>
            <div>@Model?.Volume m≥</div>
        </div>
        <div class="col-md-6">
            <div class="text-muted small fw-bold text-uppercase mb-1">Client</div>
            <div><i class="bi bi-person me-1 text-primary"></i>@Model?.Client?.Nom @Model?.Client?.Prenom ó @Model?.Client?.Ville</div>
        </div>
        <div class="col-md-6">
            <div class="text-muted small fw-bold text-uppercase mb-1">Livreur</div>
            <div><i class="bi bi-person-badge me-1 text-primary"></i>@Model?.Livreur?.CIN ó @Model?.Livreur?.Ville</div>
        </div>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="mt-4 d-flex gap-2 no-print">
            <a class="btn btn-warning text-white" asp-action="Edit" asp-route-id="@Model?.Id"><i class="bi bi-pencil me-1"></i>Modifier</a>
            <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model?.Id"><i class="bi bi-trash me-1"></i>Supprimer</a>
        </div>
    }
</div>
<div class="form-card">
    <div class="row g-3">
        <div class="col-md-6">
            <div class="mb-3">
                <div class="text-muted small fw-semibold text-uppercase mb-1">Libellť</div>
                <div class="fs-6">@(Model?.Libelle ?? "ó")</div>
            </div>
            <div class="mb-3">
                <div class="text-muted small fw-semibold text-uppercase mb-1">Date de livraison</div>
                <div class="fs-6"><i class="bi bi-calendar3 me-1 text-primary"></i>@Model?.DateLivraison.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div class="mb-3">
                <div class="text-muted small fw-semibold text-uppercase mb-1">Montant</div>
                <div class="fs-5 fw-bold text-success">@Model?.Montant.ToString("N2") DZD</div>
            </div>
        </div>
        <div class="col-md-6">
