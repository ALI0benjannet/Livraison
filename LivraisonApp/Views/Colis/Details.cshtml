@model Colis
@{
    ViewData["Title"] = "Détails colis";
    var (cls, ico, lbl) = Model?.Statut switch {
        StatutColis.EnCours => ("status-en-cours", "bi-truck", "En cours"),
        StatutColis.Livre   => ("status-livre",    "bi-check-circle-fill", "Livré"),
        _                   => ("status-en-attente", "bi-hourglass-split", "En attente")
    };
}
<div class="page-header no-print">
    <h2><i class="bi bi-box-seam me-2 text-primary"></i>Colis <span class="text-muted fw-normal">#@Model?.Id</span></h2>
    <div class="d-flex gap-2">
        <button class="btn btn-print" onclick="window.print()"><i class="bi bi-printer me-1"></i>Imprimer</button>
        <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Retour</a>
    </div>
</div>

<div class="form-card">
    <!-- Statut -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <span class="status-badge @cls fs-6"><i class="bi @ico me-1"></i>@lbl</span>
        <small class="text-muted"><i class="bi bi-hash me-1"></i>Réf. @Model?.Id</small>
    </div>

    <div class="row g-4">
        <!-- Libellé & Date -->
        <div class="col-md-6">
            <div class="detail-label">Libellé</div>
            <div class="detail-value fw-semibold fs-6">@(Model?.Libelle ?? "—")</div>
        </div>
        <div class="col-md-6">
            <div class="detail-label">Date de livraison</div>
            <div class="detail-value"><i class="bi bi-calendar3 me-1 text-primary"></i>@Model?.DateLivraison.ToString("dd/MM/yyyy HH:mm")</div>
        </div>

        <!-- Montant, Poids, Volume -->
        <div class="col-md-4">
            <div class="detail-label">Montant</div>
            <div class="detail-value fs-4 fw-bold text-success">@Model?.Montant.ToString("N2") <small class="fs-6 fw-normal">DZD</small></div>
        </div>
        <div class="col-md-4">
            <div class="detail-label">Poids</div>
            <div class="detail-value"><i class="bi bi-archive me-1 text-muted"></i>@Model?.Poids kg</div>
        </div>
        <div class="col-md-4">
            <div class="detail-label">Volume</div>
            <div class="detail-value"><i class="bi bi-box me-1 text-muted"></i>@Model?.Volume m³</div>
        </div>

        <div class="col-12"><hr class="my-0" /></div>

        <!-- Client -->
        <div class="col-md-6">
            <div class="detail-label"><i class="bi bi-person me-1"></i>Client</div>
            <div class="detail-value fw-semibold">@Model?.Client?.Nom @Model?.Client?.Prenom</div>
            <div class="text-muted small mt-1"><i class="bi bi-geo-alt me-1"></i>@Model?.Client?.Ville — @Model?.Client?.CodePostal</div>
        </div>

        <!-- Livreur -->
        <div class="col-md-6">
            <div class="detail-label"><i class="bi bi-person-badge me-1"></i>Livreur</div>
            <div class="detail-value fw-semibold">@Model?.Livreur?.RaisonSocial</div>
            <div class="text-muted small mt-1"><i class="bi bi-credit-card me-1"></i>CIN: @Model?.Livreur?.CIN — <i class="bi bi-geo-alt me-1"></i>@Model?.Livreur?.Ville</div>
        </div>

        @if (!string.IsNullOrEmpty(Model?.ImageUrl))
        {
            <div class="col-12">
                <hr class="my-0" />
            </div>
            <div class="col-12">
                <div class="detail-label"><i class="bi bi-image me-1"></i>Photo du colis</div>
                <img src="@Model.ImageUrl" alt="Photo du colis"
                     style="max-height:320px;max-width:100%;border-radius:10px;border:1px solid #dee2e6;margin-top:.5rem;" />
            </div>
        }
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="mt-4 d-flex gap-2 no-print">
            <a class="btn btn-warning text-white" asp-action="Edit" asp-route-id="@Model?.Id"><i class="bi bi-pencil me-1"></i>Modifier</a>
            <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Model?.Id"><i class="bi bi-trash me-1"></i>Supprimer</a>
        </div>
    }
</div>