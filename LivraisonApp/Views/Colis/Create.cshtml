@model Colis
<h2>Nouveau colis</h2>
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-2"><label asp-for="DateLivraison"></label><input asp-for="DateLivraison" class="form-control" /></div>
    <div class="mb-2"><label asp-for="Montant"></label><input asp-for="Montant" class="form-control" /></div>
    <div class="mb-2"><label asp-for="Poids"></label><input asp-for="Poids" class="form-control" /></div>
    <div class="mb-2"><label asp-for="Volume"></label><input asp-for="Volume" class="form-control" /></div>
    <div class="mb-2"><label asp-for="Libelle"></label><input asp-for="Libelle" class="form-control" /></div>
    <div class="mb-2"><label asp-for="ClientId"></label><select asp-for="ClientId" asp-items="ViewBag.ClientId" class="form-select"></select></div>
    <div class="mb-2"><label asp-for="LivreurId"></label><select asp-for="LivreurId" asp-items="ViewBag.LivreurId" class="form-select"></select></div>
    <button class="btn btn-primary">Enregistrer</button>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
