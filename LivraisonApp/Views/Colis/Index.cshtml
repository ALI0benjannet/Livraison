@model IEnumerable<Colis>
@{
    ViewData["Title"] = "Colis";
}
<div class="page-header">
    <h2><i class="bi bi-box-seam me-2 text-primary"></i>Gestion des colis</h2>
    @if (User.IsInRole("Admin"))
    {
        <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>Nouveau colis</a>
    }
</div>

<div class="search-toolbar">
    <div class="search-input-wrap">
        <i class="bi bi-search search-icon"></i>
        <input type="search" class="search-input" data-table-search="#dataTable" placeholder="Rechercher un colis (libellé, statut, client, livreur, montant…)  —  appuyez sur /" autocomplete="off" />
        <button type="button" class="search-clear" hidden title="Effacer"><i class="bi bi-x-circle-fill"></i></button>
    </div>
    <div class="search-meta">
        <span class="search-count"><i class="bi bi-funnel"></i><span class="search-count-num">0</span> résultats</span>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="dataTable">
            <thead>
                <tr>
                    <th>#</th><th>Photo</th><th>Libellé</th><th>Statut</th><th>Date livraison</th>
                    <th>Montant</th><th>Client</th><th>Livreur</th><th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted fw-bold">@item.Id</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="Photo"
                                     style="width:42px;height:42px;object-fit:cover;border-radius:6px;border:1px solid #dee2e6;" />
                            }
                            else
                            {
                                <span class="text-muted"><i class="bi bi-image" style="font-size:1.5rem;"></i></span>
                            }
                        </td>
                        <td class="fw-semibold">@(item.Libelle ?? "—")</td>
                        <td>
                            @{
                                var (cls, ico, lbl) = item.Statut switch {
                                    StatutColis.EnCours => ("status-en-cours", "bi-truck", "En cours"),
                                    StatutColis.Livre   => ("status-livre",    "bi-check-circle-fill", "Livré"),
                                    _                   => ("status-en-attente", "bi-hourglass-split", "En attente")
                                };
                            }
                            <span class="status-badge @cls"><i class="bi @ico me-1"></i>@lbl</span>
                        </td>
                        <td><i class="bi bi-calendar3 me-1 text-muted"></i>@item.DateLivraison.ToShortDateString()</td>
                        <td class="fw-semibold text-success">@item.Montant.ToString("N2") DT</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="avatar avatar-green" style="width:28px;height:28px;font-size:.65rem">
                                    @(item.Client?.Nom?.Length > 0 ? item.Client.Nom[0].ToString().ToUpper() : "?")
                                </div>
                                <span>@item.Client?.Nom @item.Client?.Prenom</span>
                            </div>
                        </td>
                        <td><i class="bi bi-person-badge me-1 text-muted"></i>@(((item.Livreur?.Nom ?? "") + " " + (item.Livreur?.Prenom ?? "")).Trim() is { Length: > 0 } ln ? ln : (item.Livreur?.RaisonSocial ?? item.Livreur?.CIN))</td>
                        <td class="text-center">
                            <div class="action-links justify-content-center">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id" title="Détails"><i class="bi bi-eye"></i></a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a class="btn btn-sm btn-outline-warning" asp-action="Edit" asp-route-id="@item.Id" title="Modifier"><i class="bi bi-pencil"></i></a>
                                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id" title="Supprimer"><i class="bi bi-trash"></i></a>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-box-seam"></i></div>
                                <h6>Aucun colis</h6>
                                <p>Aucun colis enregistré pour le moment.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@section Scripts {
    <script>
        if (@Model.Any().ToString().ToLower()) {
            new DataTable('#dataTable', {
                language: { url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/fr-FR.json' },
                order: [[0, 'desc']]
            });
        }
    </script>
}