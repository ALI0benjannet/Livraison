<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LivraisonApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LivraisonApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="navbar navbar-dark bg-primary px-3">
        <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-truck"></i> LivraisonApp</a>
        <div class="text-white d-flex align-items-center gap-3">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span>@User.Identity.Name</span>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button class="btn btn-light btn-sm">Logout</button>
                </form>
            }
            else
            {
                <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Login">Login</a>
            }
        </div>
    </header>
    <div class="container-fluid">
        <div class="row">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <aside class="col-md-2 bg-light border-end min-vh-100 p-3">
                    <ul class="nav flex-column">
                        <li class="nav-item"><a class="nav-link" asp-controller="Colis" asp-action="Index">Colis</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Client" asp-action="Index">Clients</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Livreur" asp-action="Index">Livreurs</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Vehicule" asp-action="Index">Vehicules</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Statistiques</a></li>
                    </ul>
                </aside>
            }
            <main class="@(User.Identity?.IsAuthenticated == true ? "col-md-10" : "col-12") p-3">
                @if (TempData["Success"] is string success)
                {
                    <div class="alert alert-success">@success</div>
                }
                @RenderBody()
            </main>
        </div>
    </div>
    <footer class="border-top footer text-muted"><div class="container">&copy; 2026 - LivraisonApp</div></footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
